{
  "name": "SpecKit Java 21 DevContainer",
  "image": "mcr.microsoft.com/devcontainers/java:21-bullseye",
  "features": {
    "ghcr.io/devcontainers/features/java:1": {
      "installMaven": true,
      "mavenVersion": "latest"
    }
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "GitHub.copilot",
        "GitHub.copilot-chat",
        "vscjava.extension-pack-for-java",
        "vscjava.vscode-maven",
        "vscjava.vscode-spring-boot-dashboard",
        "vmware.vscode-boot-dev-pack"
      ],
      "settings": {
        "java.home": "/usr/local/sdkman/candidates/java/current",
        "maven.executable.path": "/usr/local/sdkman/candidates/maven/current/bin/mvn",
        "spring-boot.ls.java.home": "/usr/local/sdkman/candidates/java/current",
        "[java]": {
          "editor.defaultFormatter": "redhat.java",
          "editor.formatOnSave": true
        },
        "editor.formatOnSave": true
      }
    }
  },
  "forwardPorts": [
    8080,
    8443,
    5005
  ],
  "portsAttributes": {
    "8080": {
      "label": "Application",
      "onAutoForward": "notify"
    },
    "8443": {
      "label": "Application (HTTPS)",
      "onAutoForward": "notify"
    },
    "5005": {
      "label": "Debug",
      "onAutoForward": "silent"
    }
  },
  "remoteEnv": {
    "PATH": "/home/vscode/.local/bin:${containerEnv:PATH}",
    "MAVEN_OPTS": "-Xmx2048m",
    "JAVA_OPTS": "-Xmx2048m"
  },
  "postCreateCommand": "export PATH=\"/home/vscode/.local/bin:$PATH\" && if ! command -v uv >/dev/null 2>&1; then curl -LsSf https://astral.sh/uv/install.sh | sh; fi && java -version && mvn -version && uv --version && (command -v specify >/dev/null 2>&1 || uv tool install specify-cli --from git+https://github.com/github/spec-kit.git@v0.7.3) && specify --version && echo 'Run /specify in Copilot Chat to start SpecKit workflow.'",
  "remoteUser": "vscode",
  "mounts": [
    "source=${localEnv:HOME}${localEnv:USERPROFILE}/.m2,target=/home/vscode/.m2,type=bind,consistency=cached"
  ]
}